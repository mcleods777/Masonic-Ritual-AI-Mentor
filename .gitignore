# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
bake.log

# env files
.env
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ritual files (lodge-specific, should not be committed)
# only encrypted .mram may exist in the rituals dir; plaintext is local-only
*.mram
*.mram.backup-*
rituals/*.md
rituals/*.txt
rituals/*.json
rituals/*.jsonl
rituals/*.yaml
rituals/*.yml
# any local backup files in rituals/ (sanitization, hand-edits, recovery)
rituals/*.backup
rituals/*.backup-*
rituals/*-backup
rituals/*.pre-*-backup

# credentials — never commit
gitkey
*.credentials
credentials.json

# plaintext ritual source files — never commit under any circumstances
files/

# gstack build artifacts
.claude/skills/gstack/node_modules/
.claude/skills/gstack/browse/dist/
.claude/skills/gstack/design/dist/
.claude/skills/gstack/bin/gstack-global-discover
.claude/skills/gstack/.agents/
.claude/skills/gstack/.factory/
.gstack/
.env.vercel-temp

# bake cache — AUTHOR-01 D-01 (content-addressed Opus cache)
rituals/_bake-cache/*
!rituals/_bake-cache/.gitignore
# Preview-bake parallel-bake sessions — per-developer experimental .mram
# copies. Cache is shared across sessions; the dirs themselves are
# entirely user-personal state.
rituals/_sessions/
rituals/*.scene-prose-backup
