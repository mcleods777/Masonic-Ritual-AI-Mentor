# Groq API Key — powers both speech-to-text (Whisper) and AI feedback (Llama 3.3)
# Get yours at https://console.groq.com/keys
# Recommended — one key, two features, free tier
GROQ_API_KEY=

# Override the feedback model (defaults to llama-3.3-70b-versatile on Groq,
# or mistral-small-latest on Mistral). Change this when Gemma 4 lands on Groq.
# FEEDBACK_MODEL=

# Mistral API Key for Voxtral text-to-speech + voice cloning
# Get yours at https://console.mistral.ai/api-keys
# Also used as fallback for AI feedback if GROQ_API_KEY is not set
MISTRAL_API_KEY=

# ElevenLabs API Key for premium text-to-speech voices
# Get yours at https://elevenlabs.io/ → Profile + API Key
# Optional — the app falls back to browser TTS if not set
ELEVENLABS_API_KEY=

# Google Cloud Text-to-Speech API Key
# Enable the API at https://console.cloud.google.com/apis/library/texttospeech.googleapis.com
# Then create an API key at https://console.cloud.google.com/apis/credentials
# Optional — the app falls back to browser TTS if not set
GOOGLE_CLOUD_TTS_API_KEY=

# Deepgram API Key for Aura-2 text-to-speech
# Get yours at https://console.deepgram.com/ → API Keys
# Optional — fast, natural-sounding TTS voices
DEEPGRAM_API_KEY=

# Kokoro TTS Server URL (self-hosted, free)
# Run Kokoro locally: https://github.com/remsky/Kokoro-FastAPI
# Point this to your running instance (OpenAI-compatible /v1/audio/speech endpoint)
# Optional — free high-quality TTS when self-hosted
KOKORO_TTS_URL=

# Anthropic API Key (LEGACY — no longer required)
# The app now uses Groq/Mistral for AI feedback instead of Claude.
# Only needed if you want to use Claude for other purposes.
# ANTHROPIC_API_KEY=

# Shared client secret for API cost-abuse protection.
# Any string (e.g. `openssl rand -hex 32`). Set BOTH variables to the SAME value.
# - Server middleware reads RITUAL_CLIENT_SECRET and requires X-Client-Secret header match.
# - Client bundle reads NEXT_PUBLIC_RITUAL_CLIENT_SECRET and sends it on every /api fetch.
# When both are unset, the middleware no-ops (dev fallback).
# This is NOT strong auth — the client value is baked into the JS bundle. It exists
# to stop drive-by curl scripts from burning your Groq/Mistral/ElevenLabs credits.
# On Vercel: `vercel env add RITUAL_CLIENT_SECRET` and `vercel env add NEXT_PUBLIC_RITUAL_CLIENT_SECRET`.
# RITUAL_CLIENT_SECRET=
# NEXT_PUBLIC_RITUAL_CLIENT_SECRET=

# ============================================================
# Pilot auth (magic-link email sign-in)
# ============================================================
# When JWT_SECRET is set, the entire site requires sign-in. When unset,
# the auth gate is a no-op (handy for local dev without email infra).

# Random secret for signing magic-link and session JWTs.
# Generate with: openssl rand -hex 32
# Rotating this value invalidates every outstanding sign-in within seconds
# (emergency kill switch for lost devices).
# JWT_SECRET=

# Comma-separated list of emails allowed to sign in. Case-insensitive;
# whitespace tolerated. Non-listed emails still get a generic 200 response
# to prevent allowlist enumeration.
# LODGE_ALLOWLIST=brother.one@example.com, brother.two@example.com

# Resend API key for sending magic-link emails.
# Get yours at https://resend.com/api-keys (free tier: 100 emails/day).
# RESEND_API_KEY=

# Sender address for magic-link emails. Must be from a domain verified in
# your Resend account, OR use `onboarding@resend.dev` for initial testing.
# MAGIC_LINK_FROM_EMAIL=mentor@example.com

# Optional: override the base URL used in magic-link emails. If unset,
# the server infers it from the x-forwarded-host header (works on Vercel
# preview deploys automatically).
# MAGIC_LINK_BASE_URL=https://masonic-ritual-ai-mentor.vercel.app

# Show the "PILOT BUILD" banner at the top of every page.
# Set to "true" to enable.
# PILOT_MODE=true

# ============================================================
# Telemetry (PostHog)
# ============================================================
# When NEXT_PUBLIC_POSTHOG_KEY is set, the site captures anonymous practice
# activity events. When unset, log() is a no-op and the privacy banner does
# not show. See PRIVACY.md for the full capture/never-capture schema.
#
# NEXT_PUBLIC_* is safe to expose — the PostHog project API key is a write
# key by design.
#
# Get yours at https://eu.posthog.com/ (recommended EU region) or https://us.posthog.com/.
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
